generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = "mysql://root:@localhost:3306/tp_grapgql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id    String @id @default(uuid())
  name  String
  email String @unique
  role  Role
  cvs   Cv[]
}

model Skill {
  id          String   @id @default(uuid())
  designation String   @unique
  cvs         Cv[]     @relation("CvSkills")
}

model Cv {
  id      String   @id @default(uuid())
  name    String
  age     Int
  job     String
  user    User     @relation(fields: [userId], references: [id])
  userId  String
  skills  Skill[]  @relation("CvSkills")
}